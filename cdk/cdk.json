{
    "app": "npx ts-node --prefer-ts-exts bin/app.ts",
    "watch": {
        "include": ["**"],
        "exclude": [
            "README.md",
            "cdk*.json",
            "**/*.d.ts",
            "**/*.js",
            "tsconfig.json",
            "package*.json",
            "yarn.lock",
            "node_modules"
        ]
    },
    "context": {
        "appName": "spring-sec-mcp",

        "embeddingModelId": "amazon.titan-embed-text-v2:0",
        "embeddingDimension": 1024,

        "ecs": {
            "cpu": 512,
            "memoryMiB": 1024,
            "containerPort": 8080,
            "desiredCount": 0,
            "minCapacity": 1,
            "maxCapacity": 10,
            "requestsPerTarget": 500
        },

        "schedule": "cron(0 15 * * ? *)",
        "scheduleTimezone": "UTC",

        "cloudflare": {
            "syncSchedule": "cron(0 6 ? * MON *)",
            "maxEntries": 60,
            "initialIpv4": [
                "173.245.48.0/20",
                "103.21.244.0/22",
                "103.22.200.0/22",
                "103.31.4.0/22",
                "141.101.64.0/18",
                "108.162.192.0/18",
                "190.93.240.0/20",
                "188.114.96.0/20",
                "197.234.240.0/22",
                "198.41.128.0/17",
                "162.158.0.0/15",
                "104.16.0.0/13",
                "104.24.0.0/14",
                "172.64.0.0/13",
                "131.0.72.0/22"
            ],
            "initialIpv6": [
                "2400:cb00::/32",
                "2606:4700::/32",
                "2803:f800::/32",
                "2405:b500::/32",
                "2405:8100::/32",
                "2a06:98c0::/29",
                "2c0f:f248::/32"
            ]
        },

        "github": {
            "org": "shutx-net",
            "repo": "spring-security-documentation-mcp-server"
        },

        "domainName": "ss-doc-mcp.shutx.net",
        "certificateArn": "arn:aws:acm:ap-northeast-1:017109258102:certificate/9c32b2b3-df6e-43c9-883c-866e78ee52dd",
        "githubTokenSecretName": "codebuild/github-token",

        "@aws-cdk/aws-iam:minimizePolicies": true,
        "@aws-cdk/core:checkSecretUsage": true,
        "@aws-cdk/aws-ecs:disableExplicitDeploymentControllerForCircuitBreaker": true,
        "@aws-cdk/aws-s3:serverAccessLogsUseBucketPolicy": true
    }
}
